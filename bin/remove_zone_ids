#!/usr/bin/env bash
# Remove Windows Zone.Identifier alternate-data-stream artifact files from the repo.
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

find "$repo_root" -type f -iname '*Zone.Identifier' -print0 |
  while IFS= read -r -d '' file; do
    echo "Removing: $file"
    rm -f -- "$file"
  done
